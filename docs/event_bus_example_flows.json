{
  "_doc": "AI Event Bus — Standardized Spec v2",

  "meta": {
    "version": "v2",
    "job_status_enum": ["queued", "processing", "completed", "failed"],
    "currency": "INR",
    "cache_ttl_seconds": 600
  },

  "event_model": {
    "event_name": "CV_PARSED_V1",
    "idempotency_key": "uuid",
    "payload": {
      "user_id": "uuid",
      "resume_id": "uuid",
      "skills": []
    }
  },

  "pipeline_job_model": {
    "pipelineJobId": "uuid",
    "user_id": "uuid",
    "status": "processing",
    "progress": {
      "total_workers": 6,
      "completed_workers": 3,
      "failed_workers": 1
    },
    "timestamps": {
      "queued_at": "ISO8601",
      "started_at": "ISO8601",
      "completed_at": null
    }
  },

  "salary_model": {
    "min": 0,
    "max": 0,
    "currency": "INR"
  },

  "GET /career/pipeline-status/:jobId": {
    "response": {
      "success": true,
      "data": {
        "pipelineJobId": "uuid",
        "status": "processing",
        "progress": {
          "total_workers": 6,
          "completed_workers": 4,
          "failed_workers": 0
        },
        "is_complete": false,
        "is_failed": false,
        "timestamps": {
          "queued_at": "ISO8601",
          "started_at": "ISO8601",
          "completed_at": null
        }
      }
    }
  },

  "intelligence_report": {
    "user_id": "uuid",
    "generated_at": "ISO8601",

    "career_health": {
      "chi_score": 72,
      "skill_gaps": ["Power BI"]
    },

    "job_matches": {
      "recommended_jobs": [
        {
          "title": "Operations Analyst",
          "match_score": 82,
          "salary": {
            "min": 800000,
            "max": 1400000,
            "currency": "INR"
          }
        }
      ]
    },

    "risk_analysis": {
      "overall_risk_score": 32,
      "risk_level": "Low"
    },

    "opportunity_radar": {
      "emerging_opportunities": []
    },

    "career_advice": {
      "timeline_months": 12
    }
  },

  "error_model": {
    "code": "ERROR_CODE",
    "message": "Human readable message",
    "retryable": true
  },

  "redis_cache_keys": {
    "worker:skill-graph:<userId>": 600,
    "worker:career-health:<userId>": 600,
    "worker:job-matching:<userId>": 600,
    "worker:risk-analysis:<userId>": 600,
    "worker:opportunity-radar:<userId>": 600,
    "worker:career-advisor:<userId>": 600
  }
}