  "retry_behaviour": {
    "description": "What happens when a worker job fails",
    "flow": [
      "Attempt 1 fails → BullMQ waits 2s → retries",
      "Attempt 2 fails → BullMQ waits 4s → retries",
      "Attempt 3 fails → isFinalAttempt=true → _storeFailure() writes error to result table → publishFailure() updates ai_pipeline_jobs.status='failed'",
      "Dashboard receives _error field in result: { _status: 'failed', error: 'Engine timeout' }"
    ],
    "backoff": "exponential: 2000ms → 4000ms → 8000ms",
    "career_advisor_override": "attempts=2, backoff=fixed 5000ms (LLM retries are expensive)"
  },

  "redis_cache_keys": {
    "description": "All Redis keys used by the event bus system",
    "keys": [
      { "key": "worker:skill-graph:<userId>",       "ttl": "10 min", "writer": "SkillGraphWorker" },
      { "key": "worker:career-health:<userId>",     "ttl": "10 min", "writer": "CareerHealthWorker" },
      { "key": "worker:job-matching:<userId>",      "ttl": "10 min", "writer": "JobMatchingWorker" },
      { "key": "worker:risk-analysis:<userId>",     "ttl": "10 min", "writer": "RiskAnalysisWorker" },
      { "key": "worker:opportunity-radar:<userId>", "ttl": "10 min", "writer": "OpportunityRadarWorker" },
      { "key": "worker:career-advisor:<userId>",    "ttl": "10 min", "writer": "CareerAdvisorWorker" },
      { "key": "dashboard:intelligence-report:<userId>", "ttl": "10 min", "writer": "intelligenceResults.service" },
      { "key": "dashboard:job-matches:<userId>",    "ttl": "10 min", "writer": "intelligenceResults.service" },
      { "key": "dashboard:risk-analysis:<userId>",  "ttl": "10 min", "writer": "intelligenceResults.service" },
      { "key": "dashboard:opportunities:<userId>",  "ttl": "10 min", "writer": "intelligenceResults.service" },
      { "key": "ai:concurrency:current",            "ttl": "60s",    "writer": "aiConcurrency.js (existing)" }
    ]
  }
}
