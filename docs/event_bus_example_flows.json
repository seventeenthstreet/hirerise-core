{
  "_doc": "AI Event Bus — Example Event Flows and API Responses",

  "event_flow_cv_upload": {
    "description": "Full async flow triggered when a user uploads a CV",
    "steps": [
      {
        "step": 1,
        "actor": "ResumeIntelligenceEngine (existing)",
        "action": "Parses CV, extracts skills",
        "output": "parsedResult = { skills: ['Python', 'SQL', ...], ... }"
      },
      {
        "step": 2,
        "actor": "resume.service.js (patched)",
        "action": "Publishes CV_PARSED event to AIEventBus",
        "code": "await bus.publish('CV_PARSED', { userId, resumeId, skills })"
      },
      {
        "step": 3,
        "actor": "AIEventBus",
        "action": "Creates pipeline job record, dispatches to 5 queues in parallel",
        "queues_dispatched": [
          "hirerise:skill-graph:queue",
          "hirerise:career-health:queue",
          "hirerise:job-matching:queue",
          "hirerise:risk-analysis:queue",
          "hirerise:opportunity-radar:queue"
        ],
        "returns": {
          "pipelineJobId": "a3f1c2d4-...",
          "queuesDispatched": 5
        }
      },
      {
        "step": "4a",
        "actor": "SkillGraphWorker (parallel)",
        "action": "Runs getUserSkillGraph + detectSkillGap, writes to cache + Supabase"
      },
      {
        "step": "4b",
        "actor": "CareerHealthWorker (parallel)",
        "action": "Runs CHI v2 engine, writes chi_score + dimensions to career_health_results"
      },
      {
        "step": "4c",
        "actor": "JobMatchingWorker (parallel)",
        "action": "Runs semantic/keyword job match, writes to job_match_results"
      },
      {
        "step": "4d",
        "actor": "RiskAnalysisWorker (parallel)",
        "action": "Runs CareerRiskPredictorEngine, writes to risk_analysis_results"
      },
      {
        "step": "4e",
        "actor": "OpportunityRadarWorker (parallel)",
        "action": "Runs OpportunityRadarEngine, writes to opportunity_radar_results"
      },
      {
        "step": 5,
        "actor": "Dashboard",
        "action": "GET /api/v1/career/intelligence-report — reads from Supabase result tables"
      }
    ],
    "client_perspective": {
      "on_upload_response": { "pipelineJobId": "a3f1c2d4-...", "status": 202 },
      "polling": "GET /api/v1/career/pipeline-status/a3f1c2d4-...",
      "when_complete": "GET /api/v1/career/intelligence-report"
    }
  },

  "POST /api/v1/career/trigger-analysis": {
    "description": "Manually trigger full pipeline refresh",
    "response_202": {
      "success": true,
      "data": {
        "pipelineJobId": "b7e2a1f3-9c4d-4e8a-b2f1-0d3e5c7a9b1d",
        "queuesDispatched": [
          "hirerise:skill-graph:queue",
          "hirerise:career-health:queue",
          "hirerise:job-matching:queue",
          "hirerise:risk-analysis:queue",
          "hirerise:opportunity-radar:queue",
          "hirerise:career-advisor:queue"
        ],
        "pollUrl": "/api/v1/career/pipeline-status/b7e2a1f3-9c4d-4e8a-b2f1-0d3e5c7a9b1d",
        "message": "Full career analysis queued. Results will be available shortly."
      }
    }
  },

