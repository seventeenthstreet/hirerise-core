{
  "_meta": {
    "title": "HireRise Onboarding API — Phase 1 Contract Spec",
    "version": "2.0.0",
    "phase": "Phase 1 — Core Data Contract",
    "date": "2026-03",
    "status": "FROZEN — additive changes only after frontend sign-off",

    "baseUrl": "/api/v1/onboarding",

    "auth": "Supabase JWT (Authorization: Bearer <access_token>)",

    "userIdFormat": "uuid (from Supabase auth.uid())",

    "errorShape": {
      "description": "All errors follow this envelope",
      "shape": {
        "success": false,
        "errorCode": "string",
        "message": "string",
        "userMessage": "string | undefined",
        "details": "object | undefined",
        "timestamp": "ISO 8601 string"
      }
    }
  },

  "standards": {
    "timestamps": "ISO 8601",
    "currency": "INR",
    "salaryUnit": "LPA",
    "jobStatusEnum": ["queued", "processing", "completed", "failed"]
  },

  "endpoints": {

    "POST /consent": {
      "auth": "required",
      "description": "Record user consent (idempotent)",

      "request": {
        "body": {
          "consentVersion": "string (required)",
          "consentSource": "string (optional, default: onboarding_step_0)",
          "referralSource": "string (optional enum)"
        }
      },

      "response": {
        "success": true,
        "data": {
          "userId": "uuid",
          "step": "consent_saved",
          "consentVersion": "string",
          "consentGrantedAt": "ISO 8601",
          "alreadyRecorded": "boolean"
        }
      }
    },

    "POST /quick-start": {
      "auth": "required",
      "description": "Initial onboarding step (async CHI triggered)",

      "request": {
        "body": {
          "jobTitle": "string (required)",
          "company": "string (required)",
          "startDate": "YYYY-MM (required)",
          "isCurrent": "boolean (default true)",
          "endDate": "YYYY-MM (required if isCurrent=false)",

          "expectedRoleIds": "string[] (optional if targetRoleFreeText provided)",
          "targetRoleFreeText": "string (optional)",

          "skills": "SkillEntry[] (optional)",
          "industryId": "string (optional)"
        }
      },

      "response": {
        "success": true,
        "data": {
          "userId": "uuid",
          "step": "quick_start_saved",
          "quickStartCompleted": true,

          "chiStatus": "generating",
          "pipelineJobId": "uuid",

          "savedAt": "ISO 8601"
        }
      }
    },

    "POST /education-experience": {
      "auth": "required",
      "description": "Profile enrichment step (all optional)",

      "request": {
        "body": {
          "education": "EducationEntry[] (optional)",
          "experience": "ExperienceEntry[] (optional)",
          "skills": "SkillEntry[] (optional)",

          "expectedRoleIds": "string[] (optional)",
          "targetRoleFreeText": "string (optional)",

          "currentSalaryLPA": "number (optional)",
          "salaryDeclined": "boolean (optional)",

          "expectedSalaryLPA": "number (optional)",
          "selfDeclaredSeniority": "enum (optional)",
          "careerGaps": "CareerGapEntry[] (optional)"
        }
      },

      "response": {
        "success": true,
        "data": {
          "userId": "uuid",
          "step": "education_experience_saved",
          "savedAt": "ISO 8601"
        }
      }
    },

    "GET /progress": {
      "auth": "required",
      "description": "Returns onboarding progress",

      "response": {
        "success": true,
        "data": {
          "userId": "uuid",

          "step": "string",
          "onboardingCompleted": "boolean",

          "progressPercent": "number",
          "quickStartCompleted": "boolean",

          "chiDataCompleteness": "number",

          "pipeline": {
            "jobId": "uuid | null",
            "status": "queued | processing | completed | failed"
          }
        }
      }
    },

    "GET /suggest-roles": {
      "auth": "required",
      "description": "Role suggestions (cached)",

      "request": {
        "query": {
          "q": "string (required)",
          "limit": "number (default 5)"
        }
      },

      "response": {
        "success": true,
        "data": {
          "suggestions": [
            {
              "roleId": "string",
              "title": "string",
              "confidence": "number (0-100)"
            }
          ]
        }
      }
    }

  },

  "types": {
    "SkillEntry": {
      "name": "string",
      "proficiency": "beginner | intermediate | advanced | expert"
    },

    "EducationEntry": {
      "qualification": "string",
      "institution": "string"
    },

    "ExperienceEntry": {
      "jobTitle": "string",
      "company": "string",
      "startDate": "YYYY-MM"
    }
  }
}