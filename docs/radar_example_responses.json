{
  "_meta": {
    "title": "AI Career Opportunity Radar API",
    "version": "2.0.0",
    "auth": "Supabase JWT (Authorization: Bearer <access_token>)",
    "currency": "INR",
    "salary_unit": "annual"
  },

  "GET /career/opportunity-radar": {
    "description": "Personalized opportunity radar",
    "response": {
      "success": true,
      "data": {
        "userId": "uuid",

        "emerging_opportunities": [
          {
            "roleId": "uuid",
            "role": "Operations Analyst",
            "industry": "Operations & Finance",

            "opportunity_score": 88,
            "match_score": 72,

            "growth_trend": "High",
            "is_emerging": false,

            "salary": {
              "min": 800000,
              "max": 1400000,
              "currency": "INR"
            },

            "skills_you_have": ["Excel", "Coordination"],
            "skills_to_learn": ["Power BI", "SQL"],

            "score_breakdown": {
              "job_growth": 35,
              "salary_growth": 22,
              "skill_demand": 23,
              "industry_growth": 8
            }
          }
        ],

        "meta": {
          "total": 5,
          "limit": 5,
          "hasMore": false,
          "generated_at": "ISO8601"
        }
      }
    }
  },

  "GET /career/emerging-roles": {
    "description": "Public emerging roles",
    "response": {
      "success": true,
      "data": {
        "roles": [
          {
            "roleId": "uuid",
            "role": "MLOps Engineer",
            "industry": "Technology",

            "opportunity_score": 91,
            "growth_trend": "Very High",
            "is_emerging": true,

            "salary": {
              "min": 2000000,
              "max": 3000000,
              "currency": "INR"
            },

            "required_skills": ["Python", "Docker"]
          }
        ],

        "meta": {
          "total": 5,
          "limit": 5,
          "generated_at": "ISO8601"
        }
      }
    }
  },

  "POST /career/opportunity-radar/refresh": {
    "description": "Admin-only refresh",
    "response": {
      "success": true,
      "data": {
        "message": "Signals refreshed",
        "upserted": 18,
        "duration_ms": 2341
      }
    }
  },

  "error_model": {
    "success": false,
    "error": {
      "code": "ERROR_CODE",
      "message": "Human readable message",
      "retryable": true
    }
  }
}