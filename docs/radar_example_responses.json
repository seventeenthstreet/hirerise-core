  "scoring_formula_example": {
    "description": "How opportunity_score is computed for 'Automation Consultant'",
    "inputs": {
      "growth_rate": 55,
      "salary_growth_rate": 25,
      "demand_score": 85,
      "industry_growth": 40
    },
    "normalised": {
      "job_growth_normalised":       55,
      "salary_growth_normalised":    41,
      "skill_demand_normalised":     85,
      "industry_growth_normalised":  80
    },
    "weighted": {
      "job_growth":      "0.35 × 55 = 19.25",
      "salary_growth":   "0.25 × 41 = 10.25",
      "skill_demand":    "0.25 × 85 = 21.25",
      "industry_growth": "0.15 × 80 = 12.00"
    },
    "opportunity_score": 63,
    "note": "Score is then rounded and capped at 99. Seed data has pre-calculated scores using known market values."
  },

  "match_score_example": {
    "description": "How match_score is computed for user vs 'Operations Analyst'",
    "user_skills": ["Excel", "Coordination", "Admin Management", "Communication", "Scheduling"],
    "required_skills": ["Power BI", "SQL", "Process Optimization", "Excel", "Business Analysis", "Coordination"],
    "direct_matches": ["Excel", "Coordination"],
    "adjacent_matches": ["Admin Management (→ Business Analysis via SkillGraph)"],
    "calculation": "(2 direct + 1×0.5 adjacent) / 6 required × 100 = 41.7% → boosted with profile context → 72",
    "match_score": 72,
    "skills_to_learn": ["Power BI", "SQL", "Process Optimization", "Business Analysis"]
  }
