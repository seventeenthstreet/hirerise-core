# =============================================================================
# HireRise Core Backend — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is gitignored.
# For production, inject all variables via GCP Secret Manager or your
# deployment platform's secrets mechanism (never via .env files on servers).
# =============================================================================

NODE_ENV=development

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=8080
APP_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── FIREBASE (Authentication) ─────────────────────────────────────────────────
# Firebase is used ONLY for JWT verification (auth.verifyIdToken).
# Choose ONE of the three options below.

FIREBASE_PROJECT_ID=your-firebase-project-id

# Option A (recommended for production) — path to service account JSON file
# Store the file outside the repo, e.g. /run/secrets/firebase-admin.json
# FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-admin.json

# Option B — individual environment variables
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Option C — local emulator (dev only)
# FIRESTORE_EMULATOR_HOST=localhost:8080

# ── SUPABASE ──────────────────────────────────────────────────────────────────
# SERVICE_ROLE key bypasses RLS — backend only, NEVER expose to frontend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=resumes

# ── AI PROVIDERS ──────────────────────────────────────────────────────────────
# aiRouter.js tries providers in order. Add at least one key.
# In production: store in GCP Secret Manager and inject at runtime.
# The admin Secrets Manager UI (POST /admin/secrets) encrypts and stores
# these in Firestore — use that for zero-downtime rotation.

# OpenRouter (PRIMARY — free models available)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic Claude (FALLBACK)
# https://console.anthropic.com/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini (BACKUP — free tier available)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — fast, free tier
# https://console.groq.com/keys
GROQ_API_KEY=

# Fireworks AI
# https://fireworks.ai/api-keys
FIREWORKS_API_KEY=

# Mistral (LAST RESORT)
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# AI router tuning
AI_PROVIDER_TIMEOUT_MS=12000
AI_FAILURE_THRESHOLD=3
AI_COOLDOWN_MS=300000

# ── ENCRYPTION ────────────────────────────────────────────────────────────────
# AES-256-GCM key for the Secrets Manager — MUST be exactly 32 ASCII characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
MASTER_ENCRYPTION_KEY=your-32-character-encryption-key

# ── CACHE ─────────────────────────────────────────────────────────────────────
CACHE_PROVIDER=memory
# Set CACHE_PROVIDER=redis and fill these for production:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_URL=redis://127.0.0.1:6379

# ── BILLING / STRIPE ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── APP BEHAVIOUR ─────────────────────────────────────────────────────────────
HIRERISE_MODE=launch
UPGRADE_URL=/pricing
RESUME_MAX_BYTES=10485760
ENABLE_AI_CV_FALLBACK=true
ADMIN_HARDENING_ENABLED=true

# Secret rotation grace window (hours)
SECRET_ROTATION_GRACE_HOURS=2

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
FEATURE_SEMANTIC_MATCHING=false
FEATURE_EVENT_BUS=false
FEATURE_PERSONALIZATION=false
RUN_ENGAGEMENT_WORKER=false
