                "exec": [
                  "pm.test('409 Conflict — punctuation-normalized collision', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        },

        {
          "name": "🔒 Security — blocked adminId injection",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}{{apiPrefix}}/admin/cms/skills",
            "header": [
