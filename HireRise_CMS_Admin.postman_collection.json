    {
      "name": "📁 Bulk CSV Import",
      "item": [

        {
          "name": "✅ Import — all clean rows",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}{{apiPrefix}}/admin/cms/import",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"datasetType\": \"skills\",\n  \"rows\": [\n    { \"name\": \"React\",      \"category\": \"framework\" },\n    { \"name\": \"Node.js\",    \"category\": \"framework\" },\n    { \"name\": \"PostgreSQL\", \"category\": \"tool\" }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created — all rows inserted', () => pm.response.to.have.status(201));",
                  "pm.test('inserted count matches row count', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.inserted).to.eql(3);",
                  "  pm.expect(body.data.total).to.eql(3);",
                  "  pm.expect(body.duplicates).to.be.an('array').with.lengthOf(0);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "✅ Import — mixed (some new, some duplicate) → 207",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}{{apiPrefix}}/admin/cms/import",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"datasetType\": \"skills\",\n  \"rows\": [\n    { \"name\": \"Python\",     \"category\": \"language\" },\n    { \"name\": \"react\",      \"category\": \"framework\" },\n    { \"name\": \"Kubernetes\", \"category\": \"tool\" },\n    { \"name\": \"NODE.JS\",    \"category\": \"framework\" }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('207 Multi-Status — partial success', () => pm.response.to.have.status(207));",
                  "pm.test('2 inserted, 2 duplicate', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.inserted).to.eql(2);",
                  "  pm.expect(body.duplicates.length).to.eql(2);",
                  "});",
                  "pm.test('duplicates identify reason as database', () => {",
                  "  pm.response.json().duplicates.forEach(d => {",
                  "    pm.expect(d.reason).to.be.oneOf(['database', 'file']);",
                  "    pm.expect(d.row).to.be.a('number');",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "✅ Import — internal file duplicates detected",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}{{apiPrefix}}/admin/cms/import",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"datasetType\": \"skills\",\n  \"rows\": [\n    { \"name\": \"Docker\",  \"category\": \"tool\" },\n    { \"name\": \"Docker\",  \"category\": \"tool\" },\n    { \"name\": \"DOCKER\",  \"category\": \"tool\" }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('1 inserted, 2 are file-level duplicates', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.inserted).to.eql(1);",
                  "  const fileDupes = body.duplicates.filter(d => d.reason === 'file');",
                  "  pm.expect(fileDupes.length).to.eql(2);",
                  "});"
                ]
              }
            }
          ]
