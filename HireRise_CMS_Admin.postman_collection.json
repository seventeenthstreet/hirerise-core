            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"TypeScript\",\n  \"category\": \"language\",\n  \"adminId\": \"injected-fake-admin\",\n  \"createdByAdminId\": \"another-fake-id\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('400 — identity injection blocked by validator', () => {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ]
        },

