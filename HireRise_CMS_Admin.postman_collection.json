                ]
              }
            }
          ]
        },

        {
          "name": "✅ Update skill — rename with dedup check",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}{{apiPrefix}}/admin/cms/skills/{{skillId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description for JavaScript\",\n  \"demandScore\": 97\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK on update', () => pm.response.to.have.status(200));",
                  "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ]
        },

        {
          "name": "✅ List skills",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/admin/cms/skills?limit=20&category=language",
              "query": [
                { "key": "limit",    "value": "20" },
                { "key": "category", "value": "language" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('returns array of skills', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.be.true;",
                  "  pm.expect(body.data).to.be.an('array');",
                  "  pm.expect(body.data.length).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "🔒 No token — 401",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}{{apiPrefix}}/admin/cms/skills"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 without token', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }

      ]
    },

