# ============================================================================
# .dockerignore — PRODUCTION SAFE (Supabase + monorepo optimized)
# Prevent large build context, secrets leakage, test payloads, and legacy files
# ============================================================================

# ============================================================================
# Node dependencies / package managers
# ============================================================================
node_modules
.pnpm-store
.npm
.yarn
.yarn-cache
.yarn/*
!.yarn/releases
!.yarn/plugins

# ============================================================================
# Environment / secrets
# ============================================================================
.env
.env.*
.env.keys
.env.local
.env.*.local
secrets/
.supabase/
.branches
.temp

# ============================================================================
# Test fixtures / payloads / debug scripts
# ============================================================================
personal.json
chi.json
career.json
body.json
gencv.json
growth.json
score.json
test.json

get-token.js
get-firebase-token.mjs
test-tier-integration.js

# ============================================================================
# Logs / debug output
# ============================================================================
*.log
firestore-debug.log
supabase-debug.log
coverage/
__tests__/

# ============================================================================
# Git / repo metadata
# ============================================================================
.git
.gitignore
.gitattributes
.github/

# ============================================================================
# Dev tooling / local configs
# ============================================================================
.eslintrc*
.prettierrc*
.editorconfig
nodemon.json
.vscode/
.idea/

# ============================================================================
# Docs / local notes
# ============================================================================
docs/
README.md
structure.txt
*.md

# ============================================================================
# Build outputs
# ============================================================================
dist/
build/
.next/
.nuxt/
.cache/
tmp/