# .dockerignore — D-07 FIX
# Prevents node_modules, secrets, and test fixtures from being
# sent to the Docker build context. Without this, build context
# can exceed 300 MB (Puppeteer Chromium) and may include .env.

node_modules
.env
.env.*
secrets/

# Test fixtures and debug scripts (C-04)
personal.json
chi.json
career.json
body.json
gencv.json
growth.json
score.json
test.json
get-token.js
get-firebase-token.mjs
test-tier-integration.js

# Logs and debug output
*.log
firestore-debug.log

# Git
.git
.gitignore

# Test coverage
coverage/
__tests__/

# Dev tooling
.eslintrc*
.prettierrc*
nodemon.json

# Docs
docs/
README.md
structure.txt
