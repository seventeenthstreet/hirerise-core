'use strict';

/**
 * validation.schemas.js — Centralized Zod Validation Schemas
 * ===========================================================
 * PRODUCTION HARDENED — Phase 1
 *
 * WHY ZOD over express-validator:
 *   - Type inference: schema doubles as TypeScript type definition
 *   - Coercion built-in (.coerce.number())
 *   - Transform pipeline: strip unknown fields before they reach services
 *   - Better error messages out of the box
 *
 * ARCHITECTURE:
 *   Schemas live here (one source of truth).
 *   Routes use validateBody/validateQuery middleware wrappers.
 *   Services receive already-validated, already-typed data.
 *   No validation logic inside controllers or services.
 *
 * ADDING NEW SCHEMAS:
 *   1. Export a new z.object() schema from this file.
 *   2. Use validateBody(yourSchema) in the route.
 *   Done. No other files need changing.
 *
 * NOTE: This codebase already uses express-validator in requestValidator.js.
 *   Both can coexist — use this for new routes, migrate old routes gradually.
 *   The middleware interface is identical from the route's perspective.
 */

const { z } = require('zod');
const { AppError, ErrorCodes } = require('./errorHandler');

// ─── Middleware factories ─────────────────────────────────────────────────────

/**
 * validateBody(schema)
 * Validates req.body against a Zod schema.
 * On success: replaces req.body with the parsed (coerced + stripped) value.
 * On failure: calls next() with a 400 AppError.
 */
function validateBody(schema) {
  return (req, res, next) => {
    const result = schema.safeParse(req.body);
    if (!result.success) {
      const fields = result.error.issues.map(issue => ({
        field:   issue.path.join('.'),
        message: issue.message,
        value:   undefined, // don't echo back PII
      }));
      return next(new AppError(
        'Request validation failed',
        400,
        { fields },
        ErrorCodes.VALIDATION_ERROR
      ));
    }
    req.body = result.data; // replace with coerced, stripped data
    next();
  };
}

/**
 * validateQuery(schema)
 * Validates req.query against a Zod schema.
 * On success: replaces req.query with parsed value.
 */
function validateQuery(schema) {
  return (req, res, next) => {
    const result = schema.safeParse(req.query);
    if (!result.success) {
      const fields = result.error.issues.map(issue => ({
        field:   issue.path.join('.'),
        message: issue.message,
      }));
      return next(new AppError(
        'Query parameter validation failed',
        400,
        { fields },
        ErrorCodes.VALIDATION_ERROR
      ));
    }
    req.query = result.data;
    next();
  };
}

// ─── Shared primitives ────────────────────────────────────────────────────────

const userId       = z.string().min(1).max(128);
const resumeId     = z.string().min(1).max(128);
const dateString   = z.string().regex(/^\d{4}-\d{2}-\d{2}$/, 'Must be YYYY-MM-DD format');

// ─── Analysis schemas ─────────────────────────────────────────────────────────

const VALID_OPERATIONS = ['fullAnalysis', 'generateCV', 'jobMatchAnalysis', 'jobSpecificCV'];

const AnalysisBodySchema = z.object({
  resumeId:      resumeId,
  operationType: z.enum(VALID_OPERATIONS, {
    errorMap: () => ({ message: `operationType must be one of: ${VALID_OPERATIONS.join(', ')}` }),
  }),
}).strict(); // reject unknown fields

const JobMatchBodySchema = z.object({
  resumeId:      resumeId,
  jobDescription: z.string().min(50, 'Job description must be at least 50 characters').max(10000),
  operationType:  z.enum(['jobMatchAnalysis', 'jobSpecificCV']),
}).strict();

// ─── Onboarding schemas ───────────────────────────────────────────────────────

const EducationEntrySchema = z.object({
  degree:           z.string().min(2).max(200),
  institution:      z.string().min(2).max(200),
  yearOfGraduation: z.coerce.number().int().min(1960).max(new Date().getFullYear() + 5).optional(),
  specialization:   z.string().max(200).optional(),
  certifications:   z.array(z.string().max(200)).max(20).default([]),
});

const ExperienceEntrySchema = z.object({
  jobTitle:         z.string().min(2).max(200),
  company:          z.string().min(1).max(200),
  industry:         z.string().max(200).optional(),
  startDate:        z.string().max(20).optional(),
  endDate:          z.string().max(20).optional(),
  isCurrent:        z.boolean().default(false),
  responsibilities: z.array(z.string().max(500)).max(20).default([]),
});

const EducationExperienceBodySchema = z.object({
  education:  z.array(EducationEntrySchema).min(0).max(10).default([]),
  experience: z.array(ExperienceEntrySchema).min(0).max(20).default([]),
}).refine(
  (data) => data.education.length > 0 || data.experience.length > 0,
  { message: 'At least one education or experience entry is required.' }
);

// ─── Admin metrics schemas ────────────────────────────────────────────────────

const VALID_PERIODS = ['7d', '30d', '90d', '1y'];

const AdminMetricsQuerySchema = z.object({
  period:    z.enum(VALID_PERIODS).optional().default('30d'),
  startDate: dateString.optional(),
  endDate:   dateString.optional(),
}).refine(
  (data) => {
    if (data.startDate && !data.endDate) return false;
    if (data.endDate && !data.startDate) return false;
    return true;
  },
  { message: 'Both startDate and endDate are required for custom range.' }
);

// ─── Salary schemas ───────────────────────────────────────────────────────────

const SalaryBenchmarkBodySchema = z.object({
  roleId:            z.string().min(1).max(128),
  experienceYears:   z.coerce.number().int().min(0).max(60),
  location:          z.string().max(100).optional(),
  skills:            z.array(z.string().max(100)).max(50).default([]),
}).strict();

// ─── Quota check schema ───────────────────────────────────────────────────────

const TierQuotaQuerySchema = z.object({
  feature: z.string().min(1).max(100),
});

module.exports = {
  // Middleware factories
  validateBody,
  validateQuery,

  // Schemas
  AnalysisBodySchema,
  JobMatchBodySchema,
  EducationExperienceBodySchema,
  AdminMetricsQuerySchema,
  SalaryBenchmarkBodySchema,
  TierQuotaQuerySchema,

  // Primitives (for reuse in custom schemas)
  userId,
  resumeId,
  dateString,
};