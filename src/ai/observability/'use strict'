'use strict';

const crypto = require('crypto');
const observabilityRepo = require('../../repositories/ai-observability.repository');

/**
 * AILogger — Structured observability logging for all AI inference calls.
 *
 * Design principles:
 *  - Non-blocking: logs are fire-and-forget (failures do NOT throw to callers)
 *  - PII-safe: raw inputs are hashed; only metadata and safe fields are stored
 *  - Model-version aware: captures model + version at call time
 *  - Latency tracked: caller provides startTime, logger computes elapsed
 *  - Token tracking: input/output tokens stored for cost computation
 *  - Confidence tracking: optional, stored as float 0–1
 *
 * Usage:
 *   const timer = AILogger.startTimer();
 *   // ... AI call ...
 *   await AILogger.log({
 *     feature: 'resume_scoring',
 *     userId: req.user.id,
 *     model: 'gpt-4o',
 *     modelVersion: '2024-11-20',
 *     inputHash: AILogger.hashInput(resumeText),
 *     outputSummary: { score: 82, tier: 'strong' },
 *     tokensInput: 1200,
 *     tokensOutput: 450,
 *     confidenceScore: 0.87,
 *     success: true,
 *     timer,
 *   });
 */
class AILogger {
  /**
   * Valid feature identifiers — enforced for consistent indexing.
   */
  static FEATURES = Object.freeze([
    'resume_scoring',
    'skill_recommendation',
    'salary_benchmark',
    'career_path',
    'resume_parsing',
  ]);

  /**
   * Start a high-resolution timer. Returns an opaque timer object.
   */
  static startTimer() {
    return { start: Date.now(), hrStart: process.hrtime.bigint() };
  }

  /**
   * Compute elapsed milliseconds from timer.
   */
  static elapsedMs(timer) {
    return Number(process.hrtime.bigint() - timer.hrStart) / 1_000_000;
  }

  /**
   * Hash a raw input string to a stable, non-reversible fingerprint.
   * SHA-256 truncated to 16 hex chars — sufficient for deduplication.
   * NEVER store raw user text in logs.
   */
  static hashInput(rawInput) {
    if (!rawInput || typeof rawInput !== 'string') return null;
    return crypto.createHash('sha256').update(rawInput).digest('hex').slice(0, 32);
  }

  /**
   * Primary log writer.
   *
   * @param {Object} params
   * @param {string} params.feature - one of FEATURES
   * @param {string} params.userId
   * @param {string} params.model - model identifier e.g. 'gpt-4o'
   * @param {string} [params.modelVersion] - model version/snapshot
   * @param {string} [params.inputHash] - hashed input (use hashInput())
   * @param {Object} [params.outputSummary] - non-PII summary of AI output
   * @param {number} [params.tokensInput]
   * @param {number} [params.tokensOutput]
   * @param {number} [params.confidenceScore] - 0 to 1
   * @param {boolean} params.success
   * @param {Object} [params.error] - { code, message } on failure
   * @param {Object} params.timer - from startTimer()
   * @param {Object} [params.metadata] - any additional safe k/v pairs
   */
  static async log(params) {
    const {
      feature,
      userId,
      model,
      modelVersion = null,
      inputHash = null,
      outputSummary = null,
      tokensInput = 0,
      tokensOutput = 0,
      confidenceScore = null,
      success,
      error = null,
      timer,
      metadata = {},
    } = params;

    // Validate feature
    if (!AILogger.FEATURES.includes(feature)) {
      console.warn(`[AILogger] Unknown feature: "${feature}" — log dropped`);
      return;
    }

    const latencyMs = timer ? AILogger.elapsedMs(timer) : null;
    const today = new Date().toISOString().split('T')[0];

    const logEntry = {
      feature,
      userId: userId || 'anonymous',
      model: model || 'unknown',
      modelVersion,
      inputHash,
      outputSummary: AILogger._sanitizeOutput(outputSummary),
      tokensInput: Number(tokensInput) || 0,
      tokensOutput: Number(tokensOutput) || 0,
      totalTokens: (Number(tokensInput) || 0) + (Number(tokensOutput) || 0),
      confidenceScore: confidenceScore != null ? Math.min(1, Math.max(0, Number(confidenceScore))) : null,
      latencyMs: latencyMs != null ? Math.round(latencyMs) : null,
      success: Boolean(success),
      errorCode: error?.code || null,
      errorMessage: success ? null : (error?.message?.slice(0, 200) || 'Unknown error'),
      date: today,
      environment: process.env.NODE_ENV || 'development',
      isDeleted: false,
      ...AILogger._safeMetadata(metadata),
    };

    // Fire-and-forget — never block the caller
    observabilityRepo.writeLog(logEntry).catch(err => {
      console.error('[AILogger] Failed to write log:', err.message);
    });
  }

  /**
   * Convenience: log a failed AI call.
   */
  static async logError(params) {
    return AILogger.log({ ...params, success: false });
  }

  /**
   * Strip any PII-like fields from output before storing.
   * Allows only primitive values and known-safe keys.
   */
  static _sanitizeOutput(output) {
    if (!output || typeof output !== 'object') return null;

    const SAFE_KEYS = new Set([
      'score', 'tier', 'grade', 'salaryMin', 'salaryMax', 'salaryMedian',
      'currency', 'skills', 'confidence', 'topSkills', 'careerStage',
      'matchPercent', 'rank', 'category', 'count', 'level',
    ]);

    const sanitized = {};
    for (const [k, v] of Object.entries(output)) {
      if (SAFE_KEYS.has(k) && (typeof v === 'number' || typeof v === 'string' || Array.isArray(v))) {
        sanitized[k] = Array.isArray(v) ? v.slice(0, 20) : v; // cap array length
      }
    }
    return Object.keys(sanitized).length > 0 ? sanitized : null;
  }

  static _safeMetadata(meta) {
    if (!meta || typeof meta !== 'object') return {};
    // Only pass through string/number primitives, no nested objects
    const safe = {};
    for (const [k, v] of Object.entries(meta)) {
      if (typeof v === 'string' || typeof v === 'number' || typeof v === 'boolean') {
        safe[`meta_${k}`] = v;
      }
    }
    return safe;
  }
}

module.exports = AILogger;