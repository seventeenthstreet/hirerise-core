# ─────────────────────────────────────────────────────────────────────────────
# HireRise Core — Environment Template
# Copy this to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── FIREBASE (choose ONE credential option) ───────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_DATABASE_URL=

# Option A — service account JSON file (relative path from project root)
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# Option B — individual env vars (comment out Option A and fill these)
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# Option C — emulator (comment out both A and B, then run: firebase emulators:start)
# FIRESTORE_EMULATOR_HOST=localhost:8080

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-opus-4-6

# ── CACHE ─────────────────────────────────────────────────────────────────────
CACHE_PROVIDER=memory
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_URL=redis://127.0.0.1:6379

# ── OPTIONAL INTEGRATIONS ─────────────────────────────────────────────────────
# Pub/Sub (omit to use setTimeout fallback for background jobs)
# PUBSUB_TOPIC_RESUME_SCORE=resume-scoring-requested

# Gotenberg PDF (omit to use Puppeteer fallback)
# GOTENBERG_URL=http://localhost:3001

# Upgrade URL shown in quota-exceeded responses
UPGRADE_URL=/pricing

HIRERISE_MODE=launch
