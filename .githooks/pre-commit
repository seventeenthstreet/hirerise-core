#!/usr/bin/env sh
# Hirerise Pre-Commit Secret Scanner
# Prevents committing secrets using Gitleaks

set -eu

echo "🔐 Running secret scan with Gitleaks..."

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "❌ Gitleaks is not installed."
  echo "Install: https://github.com/gitleaks/gitleaks"
  exit 1
fi

# Ensure we are inside a git repository
if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "❌ Not inside a Git repository."
  exit 1
fi

# Scan staged changes only
if ! gitleaks git --staged --redact --verbose; then
  echo "❌ Secret detected. Commit blocked."
  exit 1
fi

echo "✅ No secrets detected. Commit allowed."
exit 0